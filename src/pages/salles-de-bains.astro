---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Salles de bains à Nantes | Bourgeais Frédéric - Création & Rénovation" description="Création et rénovation de salles de bains clé en main à Nantes. Faïence, carrelage, sanitaires, robinetterie. Devis gratuit, délais rapides.">
  <div class="page-header">
    <div class="container">
      <p class="section-label">Nos services</p>
      <h1>Salles de bains à Nantes</h1>
      <p>Création et rénovation complète clé en main. Faïence, carrelage, sanitaires.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text reveal">
          <h2>Votre salle de bains<br>clé en main</h2>
          <p>Frédéric Bourgeais réalise l'aménagement et la création de salles de bains clé en main à Nantes et en Loire-Atlantique. Pose de faïence et carrelage, en neuf et rénovation.</p>
          <p>Nous vous garantissons un travail soigné et de qualité. Pour tout renseignement complémentaire, conseils personnalisés et devis gratuit, contactez-nous.</p>
          <div class="about-features" style="margin-top: var(--space-md);">
            <div class="about-feature"><span class="check">&#10003;</span> Prestation clé en main</div>
            <div class="about-feature"><span class="check">&#10003;</span> Neuf & rénovation</div>
            <div class="about-feature"><span class="check">&#10003;</span> Délais rapides</div>
            <div class="about-feature"><span class="check">&#10003;</span> Devis gratuit</div>
            <div class="about-feature"><span class="check">&#10003;</span> Garantie décennale</div>
            <div class="about-feature"><span class="check">&#10003;</span> Conseils personnalisés</div>
          </div>
        </div>
        <div class="about-image reveal">
          <div class="about-image-placeholder">&#128703;</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--white);">
    <div class="container">
      <div class="reveal">
        <p class="section-label">Prestations</p>
        <h2 class="section-title">Ce que nous réalisons</h2>
      </div>
      <div class="services-grid" style="grid-template-columns: repeat(2, 1fr);">
        <div class="service-card reveal">
          <div class="service-icon">&#128703;</div>
          <h3>Création complète</h3>
          <p>Conception et réalisation de votre salle de bains de A à Z. Plomberie, carrelage, faïence, sanitaires, éclairage — tout est inclus dans notre prestation clé en main.</p>
        </div>
        <div class="service-card reveal">
          <div class="service-icon">&#128295;</div>
          <h3>Rénovation</h3>
          <p>Modernisation de votre salle de bains existante. Remplacement des équipements vétustes, mise aux normes, rafraîchissement complet.</p>
        </div>
        <div class="service-card reveal">
          <div class="service-icon">&#9641;</div>
          <h3>Faïence & carrelage</h3>
          <p>Pose de faïence murale et de carrelage au sol. Grand choix de styles et de formats pour personnaliser votre espace.</p>
        </div>
        <div class="service-card reveal">
          <div class="service-icon">&#128704;</div>
          <h3>Sanitaires & robinetterie</h3>
          <p>Installation de douches, baignoires, lavabos, WC. Robinetterie de qualité : Jacob Delafon, Grohe, Hansgrohe.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--sand);">
    <div class="container">
      <div class="reveal">
        <p class="section-label">Nos engagements</p>
        <h2 class="section-title">Un travail soigné, des délais tenus</h2>
      </div>
      <div class="services-grid" style="grid-template-columns: repeat(3, 1fr);">
        <div class="service-card reveal" style="text-align: center;">
          <div class="service-icon" style="margin: 0 auto var(--space-sm);">&#128172;</div>
          <h3>Conseil</h3>
          <p>Nous vous accompagnons dans le choix des matériaux et équipements adaptés à votre budget et vos envies.</p>
        </div>
        <div class="service-card reveal" style="text-align: center;">
          <div class="service-icon" style="margin: 0 auto var(--space-sm);">&#128197;</div>
          <h3>Délais rapides</h3>
          <p>Nous nous engageons sur des délais de réalisation courts pour minimiser la gêne occasionnée.</p>
        </div>
        <div class="service-card reveal" style="text-align: center;">
          <div class="service-icon" style="margin: 0 auto var(--space-sm);">&#9989;</div>
          <h3>Qualité garantie</h3>
          <p>Respect des normes en vigueur, garantie décennale et responsabilité civile professionnelle.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <div>
        <h2>Un projet de salle de bains ?</h2>
        <p>Contactez-nous pour un devis gratuit et des conseils personnalisés.</p>
      </div>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="tel:0240434217" class="btn btn-white"><span>&#9742;</span> 02 40 43 42 17</a>
        <a href="/#contact" class="btn btn-outline" style="border-color: white; color: white;">Devis en ligne</a>
      </div>
    </div>
  </section>
</Layout>
