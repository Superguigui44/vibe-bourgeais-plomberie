---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Chauffage à Nantes | Bourgeais Frédéric - Chaudières, Pompes à chaleur" description="Chauffagiste à Nantes depuis 2001. Installation et entretien de chaudières gaz/fioul/électriques, pompes à chaleur, planchers chauffants. Remplacement sous 24h.">
  <div class="page-header">
    <div class="container">
      <p class="section-label">Nos services</p>
      <h1>Chauffage à Nantes</h1>
      <p>Vente, installation et entretien de systèmes de chauffage. Remplacement de chaudière sous 24 heures.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="about-grid">
        <div class="about-text reveal">
          <h2>Votre chauffagiste<br>depuis 2001</h2>
          <p>Nous effectuons différents travaux sur les réseaux de gaz, d'eau froide/chaude et de chauffage. Nous remplaçons les chaudières et ballons d'eau chaude électriques rapidement — sous 24 heures !</p>
          <p>Devis gratuit et rapide. TVA réduite selon la réglementation en vigueur. Possibilité de crédit et de crédit d'impôt, nous consulter.</p>
          <div class="about-features" style="margin-top: var(--space-md);">
            <div class="about-feature"><span class="check">&#10003;</span> Remplacement sous 24h</div>
            <div class="about-feature"><span class="check">&#10003;</span> Devis gratuit</div>
            <div class="about-feature"><span class="check">&#10003;</span> Crédit d'impôt</div>
            <div class="about-feature"><span class="check">&#10003;</span> TVA réduite</div>
          </div>
        </div>
        <div class="about-image reveal">
          <div class="about-image-placeholder">&#128293;</div>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--white);">
    <div class="container">
      <div class="reveal">
        <p class="section-label">Équipements</p>
        <h2 class="section-title">Nos solutions de chauffage</h2>
      </div>
      <div class="services-grid">
        <div class="service-card reveal">
          <div class="service-icon">&#128293;</div>
          <h3>Chaudières gaz</h3>
          <p>Installation, remplacement et entretien de chaudières gaz. Marques : Bosch, Saunier Duval, ELM Leblanc, Viessmann.</p>
        </div>
        <div class="service-card reveal">
          <div class="service-icon">&#9879;</div>
          <h3>Chaudières fioul</h3>
          <p>Remplacement et entretien de chaudières fioul. Nous vous conseillons sur les alternatives plus économiques.</p>
        </div>
        <div class="service-card reveal">
          <div class="service-icon">&#9889;</div>
          <h3>Chaudières électriques</h3>
          <p>Installation de chaudières électriques et ballons d'eau chaude. Remplacement rapide sous 24 heures.</p>
        </div>
        <div class="service-card reveal">
          <div class="service-icon">&#127777;</div>
          <h3>Pompes à chaleur</h3>
          <p>Installation de pompes à chaleur air/eau et air/air. Solution performante et économique pour votre confort.</p>
        </div>
        <div class="service-card reveal">
          <div class="service-icon">&#9728;</div>
          <h3>Panneaux solaires</h3>
          <p>Installation de panneaux solaires thermiques pour la production d'eau chaude sanitaire.</p>
        </div>
        <div class="service-card reveal">
          <div class="service-icon">&#128313;</div>
          <h3>Planchers chauffants</h3>
          <p>Installation de planchers chauffants hydrauliques. Confort optimal et répartition homogène de la chaleur.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--sand);">
    <div class="container">
      <div class="reveal">
        <p class="section-label">Marques partenaires</p>
        <h2 class="section-title">Nous travaillons avec les meilleures marques</h2>
      </div>
      <div class="zone-cities" style="justify-content: center;">
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">Bosch</span>
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">Saunier Duval</span>
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">ELM Leblanc</span>
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">Viessmann</span>
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">Chappée</span>
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">Acova</span>
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">Brugman</span>
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">Acome</span>
        <span class="zone-city" style="background: var(--white); color: var(--navy); border-color: rgba(11,29,58,0.1);">Rehau</span>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <div>
        <h2>Besoin d'un chauffagiste à Nantes ?</h2>
        <p>Remplacement de chaudière sous 24h. Devis gratuit.</p>
      </div>
      <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
        <a href="tel:0240434217" class="btn btn-white"><span>&#9742;</span> 02 40 43 42 17</a>
        <a href="/#contact" class="btn btn-outline" style="border-color: white; color: white;">Devis en ligne</a>
      </div>
    </div>
  </section>
</Layout>
